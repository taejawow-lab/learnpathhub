---
export interface Props { title:string; description:string; href:string; image?:string; category?:string; pubDate:Date; readingTime?:number; variant?:'feature'|'standard'; index?:number; }
const { title, description, href, image, category, pubDate, variant='standard', index=0 } = Astro.props;
const dateline = pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
const itemNum = String(index + 1).padStart(2, '0');
const saveId = href.replace(/^\//,'').replace(/\/$/,'');
---
<article class="group h-full" data-lph-card data-category={category || 'general'}>
  <a href={href} class="editorial-card block h-full overflow-hidden p-4 transition-all duration-300 hover:-translate-y-1 sm:p-5">
    {image && <div class={`${variant === 'feature' ? 'aspect-[16/9]' : 'aspect-[4/3]'} relative mb-5 overflow-hidden rounded-[1.25rem] bg-muted`}><img src={image} alt={title} loading="lazy" decoding="async" class="h-full w-full object-cover transition duration-700 group-hover:scale-[1.035]" />{category && <span class="tag absolute left-3 top-3 rounded-full px-3 py-1 text-xs font-bold uppercase tracking-[0.12em]" style="background:var(--sage-tint);color:var(--sage-700)">{category}</span>}</div>}
    <div class="mb-4 flex items-center gap-3 lph-eyebrow"><span>Path {itemNum}</span><span class="h-px w-8 bg-border"></span><time datetime={pubDate.toISOString()}>{dateline}</time></div>
    <h3 class={`${variant === 'feature' ? 'text-3xl md:text-5xl' : 'text-2xl'} mb-3 leading-[1.03] text-balance group-hover:text-primary`} style="font-family:var(--ff-serif)">{title}</h3>
    <p class="mb-5 line-clamp-3 leading-relaxed" style="color:var(--ink-2)">{description}</p>
    <div class="mt-auto flex items-center justify-between border-t border-border pt-4 text-sm font-bold"><span>Read article →</span><button type="button" class="lph-save chip" data-lph-save={saveId} data-label="Save" aria-pressed="false">Save</button></div>
  </a>
</article>
