---
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'LearnPath Hub';
const description = import.meta.env.PUBLIC_SITE_DESCRIPTION || 'Evidence-based learning systems for students and career changers.';
const currentYear = new Date().getFullYear();
---
<footer class="mt-24 border-t border-border relative overflow-hidden">
  <div class="lph-wrap py-16 md:py-24">
    <div class="grid gap-10 md:grid-cols-[1.35fr_.8fr_.8fr_.8fr]">
      <div>
        <div class="mb-5 flex items-center gap-3"><img src="/assets/lph-logo.svg" alt="" class="h-12 w-12 rounded-2xl lph-logo-mark p-2" /><strong class="text-3xl" style="font-family:var(--ff-serif)">{siteName}</strong></div>
        <p class="max-w-md text-base leading-relaxed" style="color:var(--ink-2)">{description}</p>
        <p class="mt-5 text-sm" style="color:var(--ink-3)">AI-assisted editorial production, human-reviewed source checks, and privacy-respecting static delivery.</p>
      </div>
      <div><h4 class="lph-eyebrow mb-4">Library</h4><ul class="grid gap-3 text-sm"><li><a href="/posts/">All articles</a></li><li><a href="/categories/">Categories</a></li><li><a href="/search/">Search</a></li><li><a href="/newsletter/">Newsletter</a></li></ul></div>
      <div><h4 class="lph-eyebrow mb-4">Trust</h4><ul class="grid gap-3 text-sm"><li><a href="/editorial-process/">Editorial process</a></li><li><a href="/editorial-standards/">Editorial standards</a></li><li><a href="/about/">About</a></li><li><a href="/contact/">Contact</a></li></ul></div>
      <div><h4 class="lph-eyebrow mb-4">Legal</h4><ul class="grid gap-3 text-sm"><li><a href="/privacy/">Privacy</a></li><li><a href="/terms/">Terms</a></li><li><a href="/cookie-policy/">Cookie Policy</a></li><li><a href="/disclaimer/">Disclaimer</a></li><li><a href="/affiliate-disclosure/">Affiliate disclosure</a></li></ul></div>
    </div>
    <div class="mt-12 flex flex-col gap-3 border-t border-border pt-6 text-xs uppercase tracking-[0.16em] text-muted-foreground md:flex-row md:items-center md:justify-between"><span>© {currentYear} {siteName}</span><span>Set in Newsreader + Hanken Grotesk · Built with Astro</span></div>
  </div>
</footer>
