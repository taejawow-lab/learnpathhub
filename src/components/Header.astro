---
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'LearnPath Hub';
const edition = import.meta.env.PUBLIC_SITE_EDITION || 'Learning science · AI study · Career skills';
const navItems = [
  { label: 'Articles', href: '/posts/' },
  { label: 'Library', href: '/categories/' },
  { label: 'Search', href: '/search/' },
  { label: 'About', href: '/about' },
  { label: 'Newsletter', href: '/newsletter/' },
];
---
<header class="site-header-lph">
  <div class="lph-wrap flex min-h-20 items-center justify-between gap-4">
    <a href="/" class="group flex min-w-0 items-center gap-3" aria-label={`${siteName} home`}>
      <img src="/assets/lph-logo.svg" alt="" class="h-11 w-11 rounded-2xl lph-logo-mark p-2" />
      <span class="leading-none">
        <span class="block text-2xl font-semibold tracking-[-0.03em]" style="font-family:var(--ff-serif)">{siteName}</span>
        <span class="hidden text-[11px] uppercase tracking-[0.18em] text-muted-foreground sm:block">{edition}</span>
      </span>
    </a>
    <nav aria-label="Primary navigation" class="hidden items-center gap-1 lg:flex">
      {navItems.map((item) => <a href={item.href} class="rounded-full px-3 py-2 text-sm font-bold text-foreground/75 hover:bg-muted hover:text-foreground">{item.label}</a>)}
    </nav>
    <div class="flex items-center gap-2">
      <button type="button" class="lph-btn-soft hidden sm:inline-flex" data-lph-search-open aria-label="Open search">Search <span class="text-xs opacity-60">⌘K</span></button>
      <a href="/newsletter/" class="lph-btn hidden md:inline-flex">Subscribe</a>
      <button type="button" class="lph-btn-soft h-11 w-11 px-0" data-lph-theme aria-label="Toggle theme">◐</button>
      <a href="/saved/" class="lph-btn-soft h-11 px-3" aria-label="Saved articles">★ <span class="lph-saved-badge" data-lph-saved-count hidden>0</span></a>
      <button type="button" class="lph-btn-soft h-11 px-3 lg:hidden" data-lph-menu-open aria-label="Open menu">Menu</button>
    </div>
  </div>
  <div class="lph-search-overlay" data-lph-search-overlay>
    <div class="lph-search-panel">
      <div class="flex items-center justify-between gap-3 border-b border-border p-4">
        <strong class="font-mono text-xs uppercase tracking-[0.18em]">Search LearnPath Hub</strong>
        <button type="button" class="chip" data-lph-search-close>Close</button>
      </div>
      <div class="p-4">
        <input data-lph-search-input type="search" placeholder="retrieval practice, AI tutor, career switch..." class="w-full rounded-2xl border border-border bg-background px-4 py-4 text-lg outline-none focus:border-primary" />
        <div class="mt-4 grid gap-3" data-lph-search-results></div>
      </div>
    </div>
  </div>
  <div class="lph-drawer-backdrop" data-lph-drawer-backdrop></div>
  <aside class="lph-drawer" data-lph-drawer aria-label="Mobile menu">
    <div class="mb-8 flex items-center justify-between"><strong style="font-family:var(--ff-serif);font-size:1.35rem">Menu</strong><button type="button" class="chip" data-lph-menu-close>Close</button></div>
    <nav class="grid gap-3">{navItems.map((item) => <a class="lph-card p-4 text-lg font-bold" href={item.href}>{item.label}</a>)}</nav>
  </aside>
</header>
