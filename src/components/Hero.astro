---
export interface Props { title: string; subtitle: string; illustration?: string; ctaText?: string; ctaHref?: string; }
const envIllustration = import.meta.env.PUBLIC_HAS_HERO_ILLUSTRATION === 'true' ? '/images/illustrations/hero.png' : undefined;
const { title, subtitle, illustration = envIllustration, ctaText = 'Enter the library', ctaHref = '#latest' } = Astro.props;
const today = new Date().toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }).toUpperCase();
---
<section class="relative overflow-hidden border-b border-border">
  <div class="lph-wrap py-16 md:py-24">
    <div class="mb-10 flex items-center gap-4 lph-eyebrow"><span>Learning Path Dispatch</span><span class="h-px flex-1 bg-border"></span><span>{today}</span></div>
    <div class="grid gap-10 lg:grid-cols-[1.15fr_.85fr] lg:items-end">
      <div>
        <p class="lph-eyebrow mb-5">Book + path nodes · evidence-first learning</p>
        <h1 class="max-w-4xl text-5xl leading-[.98] tracking-[-.045em] md:text-7xl lg:text-8xl" style="font-family:var(--ff-serif)">{title}</h1>
        <p class="mt-7 max-w-2xl text-xl leading-relaxed md:text-2xl" style="color:var(--ink-2)">{subtitle}</p>
        <div class="mt-9 flex flex-wrap gap-3"><a href={ctaHref} class="lph-btn">{ctaText} →</a><button type="button" class="lph-btn-soft" data-lph-search-open>Search topics ⌘K</button></div>
      </div>
      <div class="grid gap-4">
        {illustration && <img src={illustration} alt="" class="lph-card aspect-[4/3] w-full object-cover p-2" loading="eager" />}
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="path-card"><span class="num">01</span><h3 class="mt-3 text-2xl">Study systems</h3><p class="mt-2 text-sm" style="color:var(--ink-2)">Spaced repetition, retrieval practice, and exam-week planning.</p></div>
          <div class="path-card"><span class="num">02</span><h3 class="mt-3 text-2xl">AI without outsourcing</h3><p class="mt-2 text-sm" style="color:var(--ink-2)">Verification loops for notes, projects, resumes, and courses.</p></div>
        </div>
      </div>
    </div>
  </div>
</section>
