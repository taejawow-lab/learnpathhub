---
import BaseLayout from '../layouts/BaseLayout.astro';
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'LearnPath Hub';
---
<BaseLayout title="Newsletter" description={`Subscribe to ${siteName} for evidence-based learning guides and AI study workflows.`}>
  <section class="lph-wrap py-16 md:py-24">
    <div class="news-module mx-auto max-w-4xl text-center">
      <p class="lph-eyebrow justify-center">Weekly learning path</p>
      <h1 class="mt-4 text-5xl md:text-7xl" style="font-family:var(--ff-serif)">Make learning compound.</h1>
      <p class="mx-auto mt-5 max-w-2xl text-lg" style="color:var(--ink-2)">Get practical study systems, AI verification checklists, and course/tool comparison notes. No spam, no fake productivity theater.</p>
      <form class="mx-auto mt-8 flex max-w-xl flex-col gap-3 sm:flex-row" data-lph-newsletter>
        <label class="sr-only" for="newsletter-email">Email</label>
        <input id="newsletter-email" name="email" type="email" required placeholder="you@example.com" class="min-h-12 flex-1 rounded-full border border-border bg-background px-5 outline-none focus:border-primary" />
        <button class="lph-btn" type="submit">Subscribe</button>
      </form>
      <p class="mt-4 text-sm" data-lph-newsletter-status style="color:var(--ink-3)">Privacy-first placeholder: this form stores your preference locally until the real ESP is connected.</p>
    </div>
  </section>
</BaseLayout>
